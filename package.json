{
    "name": "symflow",
    "version": "2.0.0",
    "description": "A Symfony-compatible workflow engine for TypeScript and Node.js. State machines, Petri nets, guards, events, validation, and YAML/JSON/TypeScript import/export.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./engine": {
            "types": "./dist/engine.d.ts",
            "import": "./dist/engine.js",
            "require": "./dist/engine.cjs"
        },
        "./subject": {
            "types": "./dist/subject.d.ts",
            "import": "./dist/subject.js",
            "require": "./dist/subject.cjs"
        },
        "./yaml": {
            "types": "./dist/yaml.d.ts",
            "import": "./dist/yaml.js",
            "require": "./dist/yaml.cjs"
        },
        "./json": {
            "types": "./dist/json.d.ts",
            "import": "./dist/json.js",
            "require": "./dist/json.cjs"
        },
        "./typescript": {
            "types": "./dist/typescript.d.ts",
            "import": "./dist/typescript.js",
            "require": "./dist/typescript.cjs"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "import": "./dist/types.js",
            "require": "./dist/types.cjs"
        },
        "./react-flow": {
            "types": "./dist/react-flow.d.ts",
            "import": "./dist/react-flow.js",
            "require": "./dist/react-flow.cjs"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "workflow",
        "state-machine",
        "petri-net",
        "symfony",
        "transitions",
        "places",
        "guards",
        "events",
        "yaml",
        "typescript"
    ],
    "author": {
        "name": "Vandeth Tho",
        "email": "thovandeth@gmail.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/vandetho/symflow.git"
    },
    "homepage": "https://symflowbuilder.com",
    "peerDependencies": {
        "@xyflow/react": "^12.10.2"
    },
    "peerDependenciesMeta": {
        "@xyflow/react": {
            "optional": true
        }
    },
    "dependencies": {
        "js-yaml": "^4.1.1"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@xyflow/react": "^12.10.2",
        "tsup": "^8.3.5",
        "typescript": "^5.9.3"
    }
}
