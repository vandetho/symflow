{
    "name": "symflow",
    "version": "3.0.0",
    "description": "A Symfony-compatible workflow engine for TypeScript and Node.js. State machines, Petri nets, guards, events, validation, and YAML/JSON/TypeScript import/export.",
    "type": "module",
    "bin": {
        "symflow": "./dist/cli.js"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./engine": {
            "types": "./dist/engine.d.ts",
            "import": "./dist/engine.js",
            "require": "./dist/engine.cjs"
        },
        "./subject": {
            "types": "./dist/subject.d.ts",
            "import": "./dist/subject.js",
            "require": "./dist/subject.cjs"
        },
        "./yaml": {
            "types": "./dist/yaml.d.ts",
            "import": "./dist/yaml.js",
            "require": "./dist/yaml.cjs"
        },
        "./json": {
            "types": "./dist/json.d.ts",
            "import": "./dist/json.js",
            "require": "./dist/json.cjs"
        },
        "./typescript": {
            "types": "./dist/typescript.d.ts",
            "import": "./dist/typescript.js",
            "require": "./dist/typescript.cjs"
        },
        "./mermaid": {
            "types": "./dist/mermaid.d.ts",
            "import": "./dist/mermaid.js",
            "require": "./dist/mermaid.cjs"
        },
        "./graphviz": {
            "types": "./dist/graphviz.d.ts",
            "import": "./dist/graphviz.js",
            "require": "./dist/graphviz.cjs"
        },
        "./php": {
            "types": "./dist/php.d.ts",
            "import": "./dist/php.js",
            "require": "./dist/php.cjs"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "import": "./dist/types.js",
            "require": "./dist/types.cjs"
        },
        "./react-flow": {
            "types": "./dist/react-flow.d.ts",
            "import": "./dist/react-flow.js",
            "require": "./dist/react-flow.cjs"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write 'src/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts'",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "workflow",
        "state-machine",
        "petri-net",
        "symfony",
        "transitions",
        "places",
        "guards",
        "events",
        "yaml",
        "typescript",
        "mermaid",
        "symflowbuilder"
    ],
    "author": {
        "name": "Vandeth Tho",
        "email": "thovandeth@gmail.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/vandetho/symflow.git"
    },
    "homepage": "https://symflowbuilder.com",
    "peerDependencies": {
        "@xyflow/react": "^12.10.2"
    },
    "peerDependenciesMeta": {
        "@xyflow/react": {
            "optional": true
        }
    },
    "dependencies": {
        "js-yaml": "^4.1.1"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@xyflow/react": "^12.10.2",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "tsup": "^8.3.5",
        "typescript": "^6.0.3",
        "vitest": "^4.1.4"
    }
}
